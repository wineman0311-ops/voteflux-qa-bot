{
  "$schema": "https://schema.zeabur.app/template.json",
  "build": {
    "dockerfile": {
      "path": "./Dockerfile"
    }
  },
  "env": {
    "TG_BOT_TOKEN": {
      "description": "Telegram Bot Token (from @BotFather)",
      "required": true
    },
    "CRON_SCHEDULE": {
      "description": "Default cron schedule (e.g., '0 9 * * *' for daily 9am)",
      "default": "0 9 * * *"
    },
    "VF_EMAIL": {
      "description": "VoteFlux Google login email (optional)",
      "required": false
    },
    "VF_PASSWORD": {
      "description": "VoteFlux Google login password (optional)",
      "required": false
    },
    "REPORTS_DIR": {
      "description": "Directory to store generated reports",
      "default": "./reports"
    },
    "PLATFORM_STORE_PATH": {
      "description": "Path to platforms JSON config file",
      "default": "./platforms.json"
    },
    "SUBSCRIBER_STORE_PATH": {
      "description": "Path to subscriber list JSON file",
      "default": "./subscribers.json"
    },
    "CACHE_DIR": {
      "description": "Directory for same-day scrape cache",
      "default": "./cache"
    },
    "PLATFORMS_JSON": {
      "description": "Initial platforms list as JSON array (optional, overrides defaults on first run)",
      "required": false
    }
  }
}
